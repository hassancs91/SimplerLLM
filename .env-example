# =============================================================================
# SimplerLLM Environment Variables
# Copy this file to ".env" and fill in the keys for the providers you use.
# Only set the keys you need - unused providers can be left out.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY = "XXX"
ANTHROPIC_API_KEY = "XXX"
GEMINI_API_KEY = "XXX"
DEEPSEEK_API_KEY = "XXX"
COHERE_API_KEY = "XXX"
PERPLEXITY_API_KEY = "XXX"
MOONSHOT_API_KEY = "XXX"

# OpenRouter (access to 100+ models). Site vars are optional, for request tracking.
OPENROUTER_API_KEY = "XXX"
# OPENROUTER_SITE_URL = "https://yoursite.com"
# OPENROUTER_SITE_NAME = "Your App Name"

# CometAPI (access to 500+ models). COMETAPI_API_KEY is checked first,
# then COMETAPI_KEY as a fallback.
COMETAPI_API_KEY = "XXX"
# COMETAPI_KEY = "XXX"

# -----------------------------------------------------------------------------
# Embeddings
# (OpenAI / Cohere / OpenRouter / CometAPI embeddings reuse the keys above)
# -----------------------------------------------------------------------------
VOYAGE_API_KEY = "XXX"

# -----------------------------------------------------------------------------
# Image Generation
# -----------------------------------------------------------------------------
STABILITY_API_KEY = "XXX"
ARK_API_KEY = "XXX"            # Seedream (ByteDance Volcengine Ark)

# -----------------------------------------------------------------------------
# Voice / Text-to-Speech
# -----------------------------------------------------------------------------
LAHAJATI_API_KEY = "XXX"       # Lahajati TTS

# -----------------------------------------------------------------------------
# Tools: Web Search, Scraping & Data
# -----------------------------------------------------------------------------
SERPER_API_KEY = "XXX"
VALUE_SERP_API_KEY = "XXX"
SEARCHAPI_API_KEY = "XXX"      # YouTube / SearchAPI
RAPIDAPI_API_KEY = "XXX"
APIFY_API_KEY = "XXX"

# -----------------------------------------------------------------------------
# Local Models
# -----------------------------------------------------------------------------
# Ollama (no API key required)
OLLAMA_URL = "http://localhost:11434/"
OLLAMA_TIMEOUT = 120

# Hugging Face local models (no API key required)
HF_DEVICE = "auto"             # "cuda", "cpu", "mps", or "auto"
HF_TORCH_DTYPE = "auto"        # "float16", "bfloat16", "float32", or "auto"
HF_TIMEOUT = 300
HF_TRUST_REMOTE_CODE = "false"

# -----------------------------------------------------------------------------
# Global Settings - Retry Mechanism
# -----------------------------------------------------------------------------
MAX_RETRIES = 3
RETRY_DELAY = 2

# -----------------------------------------------------------------------------
# Debug Flags (optional - set to "true" to enable verbose provider logging)
# -----------------------------------------------------------------------------
# DEBUG_COMETAPI = "false"
# DEBUG_OPENROUTER = "false"
# DEBUG_DEEPSEEK = "false"
# DEBUG_MOONSHOT = "false"
# DEBUG_COHERE = "false"
# DEBUG_REASONING = "false"
